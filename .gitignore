# ---- 数据（运行时生成的用例 / 树 / 版本，不入库） ----
database/*
!database/.gitkeep

# ---- Node.js（前端） ----
node_modules/
frontend/node_modules/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

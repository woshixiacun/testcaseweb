# ---- Python（后端） ----
.venv/
backend/.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- 编辑器 / 系统 ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- 环境变量 / 密钥 ----
.env
.env.*
!.env.example
